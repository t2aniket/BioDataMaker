generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// UserDraft - Stores temporary biodata while the user is editing
model UserDraft {
  id                  String   @id @default(cuid())
  draftToken          String   @unique
  selectedLanguage    String
  selectedTemplateSlug String   // Storing slug instead of selectedTemplateId
  labelMode           String   @default("both") // "en", "native", "both"
  formData            Json     // Stores biodata JSON (name, dob, height, family details, etc.)
  photoUrl            String?  // Optional uploaded photo
  customTemplateUrl   String?  // Optional custom template background image
  
  // Privacy logic: Automatically delete drafts that expire (e.g., after 24-48 hours)
  expiresAt           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Template - Contains details of available templates
model Template {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  languageCode      String   // "en", "hi", "mr", etc.
  labelModeSupport  Json     // Array of supported label modes, e.g. ["en", "native", "both"]
  category          String   // "Simple Free", "Modern Minimal", "Classic Gold", etc.
  priceInPaise      Int      // e.g., 0 for free, 1000 for Rs 10
  isFree            Boolean  @default(false)
  requiresPayment   Boolean  @default(true)
  supportsPhoto     Boolean  @default(true)
  supportsNoPhoto   Boolean  @default(true)
  supportedExports  Json     // e.g., ["IMAGE", "PDF", "DOCX"]
  previewModeConfig Json     // configurations for preview rendering
  styleConfig       Json     // UI style config (colors, fonts, borders)
  previewImage      String
  designPackId      String?  // design pack reference if any
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  orders            Order[]
  downloads         Download[]
}

// Order - Payment and template unlock records
model Order {
  id                 String   @id @default(cuid())
  orderNumber        String   @unique // Human readable order number
  draftToken         String   // Ties back to the draft that was used to create it
  templateSlug       String
  amountInPaise      Int
  currency           String   @default("INR")
  status             String   @default("CREATED") // CREATED, PAID, FAILED, REFUNDED
  
  razorpayOrderId    String?  @unique
  razorpayPaymentId  String?  @unique
  razorpaySignature  String?
  
  customerEmail      String?
  customerPhone      String?
  
  createdAt          DateTime @default(now())
  paidAt             DateTime?

  template           Template @relation(fields: [templateSlug], references: [slug])
  downloads          Download[]
}

// Download - Tracks generation of final biodata
model Download {
  id             String   @id @default(cuid())
  orderId        String?  // Null for free templates
  draftToken     String   // Identifies the user session/data
  templateSlug   String
  exportType     String   // IMAGE, PDF, DOCX
  fileUrl        String?  // S3 or local path if generated and cached
  downloadCount  Int      @default(0)
  
  createdAt      DateTime @default(now())

  order          Order?   @relation(fields: [orderId], references: [id])
  template       Template @relation(fields: [templateSlug], references: [slug])
}

// SiteCounter - Global stats like total biodatas created
model SiteCounter {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "total_biodatas_generated"
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// AdminUser - Dashboard access
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN, SUPERADMIN
  createdAt    DateTime @default(now())
}
